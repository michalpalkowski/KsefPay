# Database
DATABASE_URL=postgres://ksef:ksef@localhost:5432/ksef

# KSeF
KSEF_ENVIRONMENT=test
KSEF_NIP=5260250274
KSEF_AUTH_METHOD=xades
# KSEF_AUTH_TOKEN=your-bootstrap-token

# Certificate (optional for test/demo — auto-generated if missing)
# For production: set both to PEM file paths or inline PEM content
# KSEF_CERT_PEM=/path/to/cert.pem
# KSEF_KEY_PEM=/path/to/key.pem

# Optional E2E test credentials
# KSEF_E2E_ENV=test
# KSEF_E2E_NIP=5260250274
# KSEF_E2E_CERT_PEM=/path/to/e2e-cert.pem
# KSEF_E2E_KEY_PEM=/path/to/e2e-key.pem

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# Logging
RUST_LOG=info,ksef_core=debug,ksef_server=debug
