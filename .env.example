# Database — choose one:
# DATABASE_URL=sqlite://./.data/ksef.db
DATABASE_URL=postgres://ksef:ksef@localhost:5432/ksef

# KSeF environment (test, demo, or production)
KSEF_ENVIRONMENT=test

# Certificate (optional — auto-generated per NIP on test/demo)
# For production: set both to PEM file paths or inline PEM content
# KSEF_CERT_PEM=/path/to/cert.pem
# KSEF_KEY_PEM=/path/to/key.pem

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# Logging
RUST_LOG=info,ksef_core=debug,ksef_server=debug
