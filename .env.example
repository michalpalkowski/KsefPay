# Database — choose one:
# DATABASE_URL=sqlite://./.data/ksef.db
DATABASE_URL=postgres://ksef:ksef@localhost:5432/ksef

# Public app URL used in invitation emails
APP_BASE_URL=http://localhost:3000

# KSeF environment (test, demo, or production)
KSEF_ENVIRONMENT=test

# Required in production.
# Generate once and keep it safe, for example:
# openssl rand -base64 32
# It encrypts stored certificates/keys at rest in the database.
# CERT_STORAGE_KEY=

# Certificate (optional — auto-generated per NIP on test/demo)
# For production: set both to PEM file paths or inline PEM content
# KSEF_CERT_PEM=/path/to/cert.pem
# KSEF_KEY_PEM=/path/to/key.pem

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# Application access mode:
# - email_invite: bootstrap admins grant access by email invite; requires SMTP
# - trusted_email: bootstrap admins add trusted emails in UI; no SMTP required
APPLICATION_ACCESS_MODE=email_invite

# SMTP email delivery
# Required only when APPLICATION_ACCESS_MODE=email_invite.
# Local development with Mailpit from docker-compose.yml:
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURITY=plaintext
SMTP_AUTH=none
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@localhost
SMTP_FROM_NAME="KSeF Pay"

# Logging
RUST_LOG=info,ksef_core=debug,ksef_server=debug

# Bootstrap admins allowed to self-register without invite.
# All other users must be invited either:
# - to the application (own workspace), using the selected APPLICATION_ACCESS_MODE
# - or to a shared workspace
ALLOWED_EMAILS=admin@example.com
